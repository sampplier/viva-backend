{
  "name": "viva-store-backend",
  "version": "1.0.1",
  "description": "Backend para VivaStore - NodeJS + Express + Prisma",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec node src/server.js",
    "start": "node src/server.js",
    "migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "test": "jest --runInBand"
  },
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.3.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^6.0.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "prisma": "^5.3.0"
  },
  "devDependencies": {
    "eslint": "^8.45.0",
    "jest": "^29.6.1",
    "nodemon": "^3.1.11",
    "prettier": "^2.8.8",
    "supertest": "^6.3.4"
  }
}
