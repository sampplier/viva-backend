# ======================================================
# 🗄️  DATABASE CONFIGURATION
# ======================================================
# Formato padrão PostgreSQL:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL='postgresql://neondb_owner:npg_AszLSnf53RbM@ep-raspy-base-a4wvmdbz-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'


# ======================================================
# 🔐 JWT AUTHENTICATION
# ======================================================
# Gere um segredo forte (por exemplo, usando: openssl rand -base64 32)
JWT_SECRET="troque-por-um-jwt-seguro"

# Token expiration (exemplos: "1h", "7d")
JWT_EXPIRES_IN="1d"


# ======================================================
# 🚀 SERVER CONFIG
# ======================================================
PORT=3333
NODE_ENV="development"


# ======================================================
# 📦 OPTIONAL – ETL / External integrations
# ======================================================
# Exemplo de URL para APIs externas usadas no ETL
EXTERNAL_API_URL="https://api.exemplo.com/data"
EXTERNAL_API_TOKEN="coloque-o-token-aqui"

# Pasta onde os arquivos processados do ETL serão salvos
ETL_OUTPUT_DIR="./etl_output"


# ======================================================
# 🧪 TEST ENVIRONMENT (OPCIONAL)
# ======================================================
# Banco dedicado aos testes automatizados (Vitest/Jest)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meuprojeto_test?schema=public"
